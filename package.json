{
  "name": "magic-cursor",
  "version": "1.0.0",
  "description": "Beautiful GPU-accelerated fluid trail that follows your mouse on every website",
  "private": true,
  "type": "module",
  "repository": "https://github.com/magic-cursor/magic-cursor.git",
  "author": {
    "name": "Magic Cursor Team",
