{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Magic Cursor",
  "version": "1.0.0",
  "identifier": "com.magiccursor.app",
  "build": {
    "devtools": true,
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Magic Cursor - Fluid Mouse Trail",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "category": "Utility",
    "shortDescription": "Beautiful GPU-accelerated fluid cursor trail",
    "longDescription": "Magic Cursor adds a mesmerizing, physics-based fluid simulation trail to your mouse cursor. Built with Vue.js, Tauri, and WebGL for cross-platform desktop support."
  }
}