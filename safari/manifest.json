{
  "manifest_version": 3,
  "name": "Magic Cursor - Fluid Mouse Trail",
  "version": "1.0.0",
  "description": "Beautiful GPU-accelerated fluid trail that follows your mouse on every website",
  "author": "Magic Cursor Team",
  "homepage_url": "https://github.com/magic-cursor/magic-cursor",

  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png",
    "256": "images/icon-256.png",
    "512": "images/icon-512.png"
  },

  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "js/background.bundle.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/contentScript.bundle.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    },
    "default_title": "Magic Cursor"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}