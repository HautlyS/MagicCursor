{
  "presets": [
    [
      "@babel/preset-env",
      {
        "useBuiltIns": false,
        "modules": false,
        "targets": {
          "chrome": "88",
          "firefox": "78",
          "opera": "74",
          "edge": "88"
        }
      }
    ],
    "@babel/preset-react",
    "@babel/preset-typescript"
  ],
  "plugins": [
    ["@babel/plugin-transform-class-properties", { "loose": true }],
    ["@babel/plugin-transform-destructuring", {
      "useBuiltIns": true
    }],
    ["@babel/plugin-transform-object-rest-spread", {
      "useBuiltIns": true
    }]
  ]
}